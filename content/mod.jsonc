		"boss_poet": "The Heavenly Poet",
		"boss_poet_desc": "Recite the scripture proclaimed by this Sage.\nYou may still strike your foes while reciting.",
		"boss_cypher": "The Cipher Lord",
		"boss_cypher_desc": "This ancient lord distorts nearby glyphs, scrambling their order.\nDestroy it with your artifacts.",
		"boss_cerberus": "Three-Headed Hellhound",
		"boss_cerberus_desc": "This demonic beast unleashes destructible projectiles.\nSever all three heads with your artifacts.",
		"boss_jormungandr": "World Serpent",
		"boss_jormungandr_desc": "This primordial serpent coils endlessly around you.\nStrike the fixed spirit marks along its path to wound the beast.",
		"boss_gemini": "Yin-Yang Twin Lords",
		"boss_gemini_desc": "Damage both twins evenly.\nThey restore each other's vitality over time up to their own limit.",
