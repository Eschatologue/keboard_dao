		"weapon_heatray_requirements": "",
		"weapon_barrage_requirements": "",
		"weapon_repeater_desc": "A devastating artifact that unleashes rapid bursts of spirit bolts in quick succession.",
		"weapon_heatray_desc": "Emits a continuous beam of concentrated solar flame, striking with perfect precision and scorching foes over time.",
		"weapon_barrage_desc": "Unleashes a storm of explosive heavenfall projectiles upon a target and its surroundings. The technique must recharge before it can be invoked again.",
		"weapon_overmind_desc": "Command a host of spirit drones through the Overmind Array, raining devastation upon your enemies.",
		"weapon_splattershot_desc": "Launch globs of corrupting essence that cripple and weaken enemies while dealing damage.",
		"weapon_wildcard_desc": "Each attack invokes one of four possible techniques at random. Wield this artifact with caution.",
		"weapon_spectre_desc": "Summons swift spectral drones that rush into melee combat, equal to the number of matches above.",
		"weapon_sentry_desc": "Deploy a heavenly sentry formation that automatically fires upon any enemy entering its range.",
		"weapon_tesla_desc": "Deploy a thunder turret that continuously discharges lightning, dealing damage over time.",
		"weapon_oscillator_desc": "Release a vibrating stream of resonant particles toward your most recent target.",
		"weapon_meteor_desc": "Periodically summon celestial targeting sigils at random locations. Activating them calls down a devastating meteor bombardment from the heavens.",
		"weapon_hunter_desc": "Summons lightning-beam drones that hunt your enemies, equal to the number of matches above.",
		"weapon_chopper_desc": "When the main artifact fires, a massive spinning sky blade is unleashed, traveling to the edge of the battlefield and cutting through all enemies in its path.",
		"weapon_minefield_desc": "Summons drifting explosive mines that detonate upon contact with enemies.",
		"weapon_blade_desc": "Deploy a rotating four-blade formation that shreds enemies who approach.",
		"weapon_firestorm_desc": "A cannon that unleashes storms of short-range explosive rounds. It circles the main artifact and must cool down before firing again.",
		"weapon_guardian_desc": "Instantly summon a guardian spirit drone that fires lasers at enemies. Fuel pickups replenish its power; once the fuel is exhausted, the guardian withdraws.",
		"weapon_orbiter_desc": "Summon a spirit orb that circles the main artifact, damaging everything it touches.",
